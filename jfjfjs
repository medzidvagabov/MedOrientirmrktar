@media (min-width: 768px) {
  .add-event-form { grid-template-columns: repeat(2, 1fr); }
  .add-event-form .full-width { grid-column: span 2; }
}
.add-event-form input,
.add-event-form textarea {
  padding: .5rem .75rem;
  border-radius: .5rem;
  border: 1px solid var(--slate-200);
  font-size: .875rem;
  outline: none;
}
.add-event-form input:focus,
.add-event-form textarea:focus { border-color: var(--brand-500); }

/* ── ОТЗЫВЫ ───────────────────────────────────────────────── */
.review-card {
  padding: 1rem;
  border-radius: 1rem;
  border: 1px solid var(--slate-100);
  background: #fff;
}
.review-card + .review-card { margin-top: .75rem; }
.review-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.review-org-name { font-weight: 700; }
.review-count { font-size: .75rem; color: var(--slate-500); }
.review-avg { font-size: 1.5rem; font-weight: 800; text-align: right; }
.review-stars { font-size: .75rem; color: var(--amber-500); }

.review-item {
  margin-top: .75rem;
  padding-top: .75rem;
  border-top: 1px solid var(--slate-100);
  font-size: .875rem;
}
.review-item-header {
  display: flex;
  align-items: center;
  gap: .5rem;
}
.review-item-stars { color: var(--amber-500); }
.review-item-date { font-size: .75rem; color: var(--slate-500); }
.review-item-text { color: var(--slate-700); margin-top: .25rem; }

.review-form {
  margin-top: .75rem;
  padding-top: .75rem;
  border-top: 1px solid var(--slate-100);
}
.review-form textarea {
  width: 100%;
  padding: .5rem .75rem;
  border-radius: .5rem;
  border: 1px solid var(--slate-200);
  font-size: .875rem;
  outline: none;
  resize: vertical;
}
.review-form textarea:focus { border-color: var(--brand-500); }

/* ── МЕРОПРИЯТИЯ ──────────────────────────────────────────── */
.event-card {
  padding: 1rem;
  border-radius: 1rem;
  border: 1px solid var(--slate-100);
  background: #fff;
  display: flex;
  align-items: flex-start;
  gap: 1rem;
}
.event-card + .event-card { margin-top: .75rem; }
.event-date-badge {
  width: 3.5rem;
  height: 3.5rem;
  border-radius: .75rem;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #fff;
  flex-shrink: 0;
}
.event-date-month { font-size: 10px; text-transform: uppercase; }
.event-date-day { font-size: 1.125rem; font-weight: 800; line-height: 1; }
.event-title { font-weight: 700; }
.event-meta { font-size: .75rem; color: var(--slate-500); margin-top: .125rem; }
.event-desc { font-size: .875rem; color: var(--slate-600); margin-top: .5rem; }
.event-register-btn {
  margin-top: .5rem;
  font-size: .875rem;
  font-weight: 600;
  background: none;
  border: none;
  cursor: pointer;
  color: var(--brand-600);
}
.event-register-btn:hover { text-decoration: underline; }
.event-register-btn.registered { color: var(--teal-600); }

/* ── УВЕДОМЛЕНИЯ ──────────────────────────────────────────── */
.notif-item {
  padding: .75rem;
  border-radius: .75rem;
  border: 1px solid var(--slate-100);
  background: #fff;
}
.notif-item + .notif-item { margin-top: .5rem; }
.notif-item.unread {
  border-color: var(--brand-300);
  background: var(--sky-50);
}
.notif-text { font-size: .875rem; }
.notif-date { font-size: 11px; color: var(--slate-500); margin-top: .25rem; }
.mark-read-btn {
  margin-top: 1rem;
  font-size: .875rem;
  font-weight: 600;
  color: var(--brand-600);
  background: none;
  border: none;
  cursor: pointer;
}
.mark-read-btn:hover { text-decoration: underline; }

/* ── ЧАТ ──────────────────────────────────────────────────── */
.chat-container {
  padding: 1.25rem;
  display: flex;
  flex-direction: column;
  height: 600px;
}
.chat-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.chat-partner-label { font-size: .75rem; color: var(--slate-500); }
.chat-partner-name { font-weight: 700; }

.chat-messages {
  flex: 1;
  overflow-y: auto;
  margin-top: 1rem;
  display: flex;
  flex-direction: column;
  gap: .5rem;
  padding-right: .5rem;
}
.chat-msg {
  max-width: 80%;
  padding: .625rem 1rem;
  border-radius: 1rem;
  font-size: .875rem;
  box-shadow: var(--shadow-sm);
}
.chat-msg.sent {
  margin-left: auto;
  background: linear-gradient(135deg, #0284c7, #14b8a6);
  color: #fff;
  border-bottom-right-radius: .375rem;
}
.chat-msg.received {
  background: var(--slate-100);
  color: var(--slate-800);
  border: 1px solid var(--slate-200);
  border-bottom-left-radius: .375rem;
}
.chat-msg-time {
  font-size: 10px;
  margin-top: .25rem;
  text-align: right;
}
.chat-msg.sent .chat-msg-time { color: rgba(255,255,255,.7); }
.chat-msg.received .chat-msg-time { color: var(--slate-500); }

.chat-empty {
  text-align: center;
  color: var(--slate-400);
  padding: 2rem;
  font-size: .875rem;
}
.chat-empty-icon { font-size: 1.875rem; margin-bottom: .5rem; }

.chat-input-form {
  margin-top: .75rem;
  display: flex;
  gap: .5rem;
}
.chat-input-form input {
  flex: 1;
  padding: .625rem 1rem;
  border-radius: .75rem;
  border: 1px solid var(--slate-200);
  outline: none;
  font-size: .875rem;
}
.chat-input-form input:focus { border-color: var(--brand-500); }
.chat-input-form .btn-primary { padding: .625rem 1rem; }
.chat-input-form .btn-primary svg { width: 1rem; height: 1rem; }

/* ── ВАКАНСИЯ ДЕТАЛИ ──────────────────────────────────────── */
.vac-detail-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
}
.vac-detail-title { margin-top: .5rem; font-size: 1.5rem; font-weight: 800; }
.vac-detail-meta { margin-top: .25rem; font-size: .875rem; color: var(--slate-600); }
.vac-detail-desc-card {
  margin-top: 1.25rem;
  padding: 1rem;
  border-radius: .75rem;
  background: var(--slate-50);
  border: 1px solid var(--slate-100);
}
.vac-detail-desc-label { font-size: .75rem; font-weight: 600; color: var(--slate-500); text-transform: uppercase; }
.vac-detail-desc-text { margin-top: .25rem; font-size: .875rem; color: var(--slate-700); }
.vac-detail-actions { margin-top: 1.25rem; display: flex; gap: .75rem; }
.vac-detail-actions .btn-primary,
.vac-detail-actions .btn-ghost { flex: 1; }

/* ── РЕЗУЛЬТАТЫ АНКЕТЫ ────────────────────────────────────── */
.results-intro {
  padding: 1rem;
  border-radius: 1rem;
  border: 1px solid var(--slate-100);
  margin-bottom: 1rem;
}
.results-intro p { font-size: .875rem; color: var(--slate-600); }

.result-card {
  padding: 1rem;
  border-radius: 1rem;
  border: 1px solid var(--slate-100);
  background: #fff;
  transition: transform .35s ease, box-shadow .35s ease;
}
.result-card:hover {
  transform: translateY(-6px);
  box-shadow: 0 20px 40px -20px rgba(2,132,199,.35);
}
.result-card + .result-card { margin-top: .75rem; }
.result-card.top { border-color: var(--brand-300); background: var(--sky-50); }
.result-card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.result-card-left { display: flex; align-items: center; gap: .75rem; }
.result-card-icon { font-size: 1.875rem; }
.result-card-name { font-weight: 700; font-size: 1.125rem; }
.result-card-reason { font-size: .75rem; color: var(--slate-500); margin-top: .125rem; }
.result-card-score { font-size: 1.5rem; font-weight: 800; text-align: right; }
.result-card-score-label { font-size: 10px; color: var(--slate-500); text-transform: uppercase; }

.result-red-flag {
  margin-top: .75rem;
  padding-top: .75rem;
  border-top: 1px solid var(--slate-100);
  display: flex;
  align-items: flex-start;
  gap: .5rem;
  font-size: .75rem;
  color: var(--rose-700);
}
.result-red-flag-icon { color: var(--rose-500); }

.results-hint {
  margin-top: 1rem;
  padding: 1rem;
  border-radius: 1rem;
  background: var(--amber-50);
  border: 1px solid var(--amber-100);
  font-size: .875rem;
  color: var(--amber-900);
}

/* ── ЗАКРЫТЬ КНОПКА МОДАЛКИ ──────────────────────────────── */
.modal-close-btn {
  width: 2.25rem;
  height: 2.25rem;
  border-radius: .5rem;
  background: transparent;
  border: none;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: background .15s ease;
}
.modal-close-btn:hover { background: var(--slate-100); }
.modal-close-btn svg { width: 1.25rem; height: 1.25rem; }

/* ── МОДАЛКА: SUBTITLE ───────────────────────────────────── */
.modal-subtitle {
  font-size: .75rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: .05em;
}
.modal-title {
  margin-top: .25rem;
  font-size: 1.5rem;
  font-weight: 800;
}

/* ── МОДАЛКА: HEADER ROW ─────────────────────────────────── */
.modal-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
}

/* ── ТОСТ-КОНТЕЙНЕР ───────────────────────────────────────── */
#toastContainer {
  position: fixed;
  top: 1rem;
  right: 1rem;
  z-index: 100;
  display: flex;
  flex-direction: column;
  gap: .5rem;
}

/* ── PRINT AREA ───────────────────────────────────────────── */
#printArea.hidden { display: none; }

/* ── ИНТЕНСИВНОСТЬ В АНКЕТЕ ──────────────────────────────── */
.intensity-row.hidden { display: none; }

/* ── АКЦЕВНЫЕ ЦВЕТА ДЛЯ ИНПУТОВ ──────────────────────────── */
input[type="radio"] { accent-color: var(--brand-600); }

/* ── OUTLINE NONE ─────────────────────────────────────────── */
.outline-none { outline: none; }

/* ── FOCUS РИНГ ───────────────────────────────────────────── */
.focus\:ring-2:focus { box-shadow: 0 0 0 2px rgba(14,165,233,.2); }
.focus\:ring-brand-100:focus { box-shadow: 0 0 0 3px rgba(14,165,233,.15); }
.focus\:border-brand-500:focus { border-color: var(--brand-500); }

/* ── ВСПЛЫВАЮЩИЕ ПОДСКАЗКИ ────────────────────────────────── */
[title] { cursor: help; }

/* ── КНОПКА С ИКОНКОЙ ────────────────────────────────────── */
.icon-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  border: none;
  background: transparent;
  cursor: pointer;
  padding: 0;
}
.icon-btn svg { pointer-events: none; }

/* ── ПЛАВНАЯ ПРОКРУТКА ЯКОРЕЙ ────────────────────────────── */
a[href^="#"] { transition: none; }

/* ── АДАПТИВНЫЕ УТИЛИТЫ ──────────────────────────────────── */
@media (min-width: 640px) {
  .sm\:inline-flex { display: inline-flex; }
  .sm\:inline { display: inline; }
  .sm\:text-5xl { font-size: 3rem; }
  .sm\:grid-cols-3 { grid-template-columns: repeat(3, minmax(0,1fr)); }
}
@media (min-width: 768px) {
  .md\:flex-row { flex-direction: row; }
}
@media (min-width: 1024px) {
  .lg\:flex { display: flex; }
  .lg\:hidden { display: none; }
  .lg\:py-24 { padding-top: 6rem; padding-bottom: 6rem; }
  .lg\:text-left { text-align: left; }
  .lg\:border-r { border-right-width: 1px; border-right-style: solid; }
}
@media (max-width: 1023px) {
  .lg\:hide { display: none; }
}
@media (max-width: 639px) {
  .sm\:hide { display: none; }
}